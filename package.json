{
  "name": "ghl-observability-copilot",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "build": "pnpm -r build",
    "build:api": "pnpm --filter api build",
    "build:web": "pnpm --filter web-component build",
    "dev": "pnpm --parallel --filter api --filter web-component dev",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web-component dev",
    "start": "pnpm --filter api start"
  }
}
